{% extends '@OHMediaBackend/base.html.twig' %}

{% block meta_title %}Scripts{% endblock %}

{% block breadcrumbs %}
  {{ bootstrap_breadcrumbs(
    bootstrap_breadcrumb(bootstrap_icon('code-slash') ~ ' Scripts', 'script_index'),
  ) }}
{% endblock %}

{% set can_create_script = is_granted(attributes.create, new_script) %}

{% set create_script_href = path('script_create') %}

{% block actions %}
  {% if can_create_script %}
    <a href="{{ create_script_href }}" class="btn btn-primary">
      {{ bootstrap_icon('plus-lg') }}
      Add Script
    </a>
  {% endif %}
{% endblock %}

{% macro whitelist(iframe_src_prefixes, script_src_prefixes) %}
  <ul class="mb-0">
    {% for iframe_src_prefix in iframe_src_prefixes %}
      <li>
        <code>{{ '<iframe src="' ~ iframe_src_prefix ~ '..."></iframe>' }}</code>
      </li>
    {% endfor %}

    {% for script_src_prefix in script_src_prefixes %}
      <li>
        <code>{{ '<script src="' ~ script_src_prefix ~ '..."></script>' }}</code>
      </li>
    {% endfor %}
  </ul>
{% endmacro %}

{% block main %}
  {% set script_count = scripts|length %}

  {% set has_whitelist = iframe_src_prefixes or script_src_prefixes %}

  {% if has_whitelist and app.user.isTypeDeveloper %}
    <div class="alert alert-warning">
      <p>As a developer user, you can bypass the whitelist in effect, but you could cause a script to no longer meet the whitelist requirements:</p>

      {{ _self.whitelist(iframe_src_prefixes, script_src_prefixes) }}
    </div>
  {% endif %}

  {% if not app.user.isTypeDeveloper %}
    <div class="alert alert-info">
      {% if has_whitelist %}
        <p>Scripts are managed by the development team to ensure security and site stability. You can view active scripts and their placements.</p>
        <p>You may also maintain scripts whose content resembles one of the following:</p>

        {{ _self.whitelist(iframe_src_prefixes, script_src_prefixes) }}
      {% else %}
        <p class="mb-0">Scripts are managed by the development team to ensure security and site stability. You can view active scripts and their placements, but only developers can create or edit them.</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="card">
    <div class="card-body">
      <div class="card-title card-title-with-count">
        <h1 class="card-title-heading">Scripts</h1>
        <div class="card-title-count">
          {{ bootstrap_badge_primary(script_count) }}
        </div>
      </div>

      {% if script_count %}
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Name</th>
              <th>Shortcode</th>
              <th>Last Updated</th>
              <th aria-label="Row Actions"></th>
            </tr>
          </thead>
          <tbody>
            {% for script in scripts %}
              {{ _self.table_row(script, attributes) }}
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p>
          No scripts found.
          {% if can_create_script %}
            <a href="{{ create_script_href }}">Click here to add an script.</a>
          {% endif %}
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}

{% macro table_row(script, attributes) %}
  {% set row_actions = [] %}

  {% if is_granted(attributes.edit, script) %}
    {% set row_actions = row_actions|merge([{
      route: 'script_edit',
      route_params: {id: script.id},
      color: 'secondary',
      icon: 'pencil',
      text: 'Edit Script',
    }]) %}
  {% endif %}

  {% if is_granted(attributes.delete, script) %}
    {% set row_actions = row_actions|merge([{
      route: 'script_delete',
      route_params: {id: script.id},
      color: 'danger',
      icon: 'trash',
      text: 'Delete Script',
      confirm: 'Are you sure you want to delete this script? Clicking OK will take you to a verification step to delete this entry.',
    }]) %}
  {% endif %}

  <tr>
    <td>{{ script }}</td>
    <td>{{ shortcode('script(' ~ script.id ~ ')') }}</td>
    <td>{{ script.updatedAt|datetime }}</td>
    <td>
      {% include '@OHMediaBackend/widget/row_actions.html.twig' with {
        row_actions: row_actions,
      } only %}
    </td>
  </tr>
{% endmacro %}
